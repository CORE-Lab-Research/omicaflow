# OmicaFlow Main Snakefile
# Reads config/base.yaml and includes rules based on module toggles

configfile: "config/base.yaml"

# Set Snakemake options
# Include module rules based on config toggles
modules = config["modules"]
cancer_type = config["project"]["cancer_type"]

if modules["acquisition"]["enabled"]:
    include: "rules/acquisition.smk"
    
if modules["qc"]["enabled"]:
    include: "rules/qc.smk"
    
if modules["dna"]["enabled"]:
    include: "rules/dna.smk"
    
if modules["rna"]["enabled"]:
    include: "rules/rna.smk"
    
if modules["methylation"]["enabled"]:
    include: "rules/methylation.smk"

if modules["integration"]["enabled"]:
    include: "rules/integration.smk"

if modules["survival"]["enabled"]:
    include: "rules/survival.smk"
    
if modules["reporting"]["enabled"]:
    include: "rules/reporting.smk"

# Define target files based on enabled modules
targets = []
if modules["acquisition"]["enabled"]:
    targets.append(f"data/raw/{cancer_type}/sample_map.tsv")
if modules["qc"]["enabled"]:
    targets.append(f"data/qc/{cancer_type}/QC_report.html")
if modules["dna"]["enabled"]:
    targets.append(f"results/dna/{cancer_type}/Driver_genes.tsv")
if modules["rna"]["enabled"]:
    targets.append(f"results/rna/{cancer_type}/DEG_results.tsv")
if modules["methylation"]["enabled"]:
    targets.append(f"results/methylation/{cancer_type}/DMP_results.tsv")
if modules["integration"]["enabled"]:
    targets.append(f"results/integration/{cancer_type}/converging_genes.tsv")
if modules["survival"]["enabled"]:
    targets.append(f"results/survival/{cancer_type}/survival_results.tsv")
if modules["reporting"]["enabled"]:
    targets.append(f"results/reports/{cancer_type}/OmicaFlow_Report.html")

rule all:
    input:
        targets