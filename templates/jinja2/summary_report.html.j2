<!DOCTYPE html>
<html>
<head>
    <title>OmicaFlow Report - {{ cancer_type }}</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        h1 { color: #2c3e50; }
        h2 { color: #3498db; border-bottom: 1px solid #eee; padding-bottom: 10px; }
        table { border-collapse: collapse; width: 100%; margin: 20px 0; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        .metric { font-size: 24px; color: #27ae60; font-weight: bold; }
        .module-section { margin: 30px 0; padding: 20px; background: #f9f9f9; }
    </style>
</head>
<body>
    <h1>OmicaFlow Multi-Omics Analysis Report</h1>
    <p><strong>Project:</strong> {{ project_name }}</p>
    <p><strong>Cancer Type:</strong> {{ cancer_type }}</p>
    <p><strong>Generated:</strong> {{ generation_date }}</p>

    <div class="module-section">
        <h2>DNA Analysis Summary</h2>
        <p>Total SNV mutations: <span class="metric">{{ dna_total_snv }}</span></p>
        <p>Driver genes identified: <span class="metric">{{ dna_driver_genes }}</span></p>
        <p>Top driver genes:</p>
        <table>
            <tr><th>Gene</th><th># Samples</th><th>MAF</th></tr>
            {% for gene in dna_top_genes %}
            <tr><td>{{ gene.gene }}</td><td>{{ gene.n_samples }}</td><td>{{ "%.3f"|format(gene.maf) }}</td></tr>
            {% endfor %}
        </table>
    </div>

    <div class="module-section">
        <h2>RNA Analysis Summary</h2>
        <p>Differentially Expressed Genes: <span class="metric">{{ rna_deg_count }}</span></p>
        <p>Up-regulated: {{ rna_up_count }}</p>
        <p>Down-regulated: {{ rna_down_count }}</p>
    </div>

    <div class="module-section">
        <h2>Methylation Analysis Summary</h2>
        <p>Differentially Methylated Probes: <span class="metric">{{ meth_dmp_count }}</span></p>
    </div>

    <div class="module-section">
        <h2>Sample Summary</h2>
        <p>Total matched samples: <span class="metric">{{ total_samples }}</span></p>
    </div>

    <hr>
    <p><em>Generated by OmicaFlow v1.0 | {{ timestamp }}</em></p>
</body>
</html>